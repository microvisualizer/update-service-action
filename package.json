{
  "name": "update-service-action",
  "version": "1.0.0",
  "description": "GitHub Action to sync a service definition to a MicroVisualizer project",
  "main": "dist/index.js",
  "scripts": {
    "package": "ncc build src/index.ts -o dist --license licenses.txt",
    "typecheck": "tsc",
    "lint": "eslint .",
    "fix": "eslint --fix .",
    "format": "prettier --write .",
    "test": "vitest run"
  },
  "keywords": [
    "github-action",
    "microvisualizer"
  ],
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "js-yaml": "^4.1.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "@types/node-fetch": "^2.6.13",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^9.39.0",
    "globals": "^16.0.0",
    "nock": "^13.4.0",
    "prettier": "^3.8.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
